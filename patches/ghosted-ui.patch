+  if (Command* command = Commands::instance()->byId("GhostlingNewCosmetic")) {
+    UIContext::instance()->executeCommandFromMenuOrShortcut(command);
+  }
+  else {
+    onOpenGhostlingGuide();
+  }
+}
+
+void HomeView::onOpenGhostlingGuide()
+{
+  Command* command = Commands::instance()->byId(CommandId::OpenBrowser());
+  if (!command)
+    return;
+
+  std::string filename = "CUSTOMIZATION.md";
+  const auto customGuide = base::normalize_path(
+    base::join_path(base::get_file_path(base::get_app_path()), "../../CUSTOMIZATION.md"));
+  if (base::is_file(customGuide))
+    filename = customGuide;
+
+  Params params;
+  params.set("filename", filename.c_str());
+  UIContext::instance()->executeCommandFromMenuOrShortcut(command, params);
+}
